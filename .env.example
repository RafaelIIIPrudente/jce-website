# =============================================================================
# Copy this file to .env.local and fill in values:
#   cp .env.example .env.local
#
# Required at minimum: the four Supabase / Database vars at the top.
# Everything else is optional — env.ts marks 3rd-party keys as .optional()
# so the app boots even if you haven't signed up for those services yet.
# =============================================================================

# --- Supabase (REQUIRED) ---
# Local dev: run `pnpm dlx supabase@latest start` (requires Docker) and paste
# the printed values here. For production, use the values from your hosted
# Supabase project's API settings.
#
# Tip — for LOCAL dev only, Supabase emits deterministic JWTs that work
# against http://127.0.0.1:54321. Safe to share, but useless outside localhost:
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
#   SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Database / Drizzle (REQUIRED) ---
# Local Supabase Postgres: postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=

# --- Email (Resend) — sign up at https://resend.com ---
RESEND_API_KEY=

# --- Payments (Stripe) — https://dashboard.stripe.com/test/apikeys ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Analytics (PostHog) — https://app.posthog.com/project/settings ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# --- Errors (Sentry) — populated by `pnpm dlx @sentry/wizard@latest -i nextjs` ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Rate limiting (Upstash) — https://console.upstash.com ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Background jobs (Inngest) — https://app.inngest.com ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- AI providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
