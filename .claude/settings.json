{
  "permissions": {
    "allow": [
      "Bash(pnpm install:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm start:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm db:push:*)",
      "Bash(pnpm db:studio:*)",
      "Bash(pnpm db:generate:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/quality-gate.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_FLOW_DISABLE_AUTOCOMMIT": "1",
    "AUTO_PUSH": "false"
  }
}
